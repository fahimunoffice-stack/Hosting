# ════════════════════════════════════════════════════════════
#  Hosting AI Backend v3 — Environment Configuration
# ════════════════════════════════════════════════════════════

# ─── AI Providers ────────────────────────────────────────────
AI_PROVIDER=claude

ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=anthropic/claude-sonnet-4
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ─── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT (public API users) ──────────────────────────────────
JWT_SECRET=change_this_random_64char_string_for_api_users
JWT_EXPIRES_IN=7d

# ─── ADMIN PANEL (KEEP SECRET) ───────────────────────────────
# Change this to a random string — this IS your admin URL path!
# Nobody can find the admin panel without knowing this path.
# Example: /admin-x7k2p9mw or /control-8fj3ks91
ADMIN_SECRET_PATH=/admin-CHANGE_THIS_NOW

# Separate JWT secret for admin sessions (different from user JWT)
ADMIN_JWT_SECRET=completely_different_64char_secret_for_admin_only
ADMIN_JWT_EXPIRES_IN=8h

# Initial admin credentials (auto-created on first npm run setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.lovable.app,https://yourdomain.com

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
ADMIN_RATE_LIMIT_MAX=10

# ─── Logging ─────────────────────────────────────────────────
LOG_DIR=./logs
LOG_MAX_FILES=30d
LOG_MAX_SIZE=20m

# ─── AI Settings ─────────────────────────────────────────────
MAX_TOKENS=3000
LOG_MAX_CHARS=12000

# ─── Company ─────────────────────────────────────────────────
COMPANY_NAME=HostPro
SUPPORT_EMAIL=support@hostpro.com
